---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead
			title="找我合作 · Angie Hu"
			description="想聊 IP 授權、藝術合作或 AI 工具?寫封信給我,我會用 Email 回覆你。"
		/>
	</head>
	<body>
		<Header />
		<main class="contact-main">
			<h1>找我合作</h1>
			<p class="lede">
				想聊 <strong>IP 授權</strong>、<strong>藝術合作</strong>、<strong>顧問</strong>,或對我的
				<strong>AI 工具</strong>有興趣?留下訊息,我會用 Email 回覆你 📮
			</p>

			<form id="contact-form" novalidate>
				<div class="grid2">
					<label>
						<span>怎麼稱呼你 *</span>
						<input type="text" name="name" required maxlength="100" autocomplete="name" />
					</label>
					<label>
						<span>你的 Email *</span>
						<input type="email" name="email" required maxlength="200" autocomplete="email" />
					</label>
				</div>
				<label>
					<span>主題</span>
					<input
						type="text"
						name="subject"
						maxlength="150"
						placeholder="例如:IP 授權合作、工具詢問…"
					/>
				</label>
				<label>
					<span>想說的話 *</span>
					<textarea name="message" required rows="7" maxlength="4000"></textarea>
				</label>
				<!-- 蜜罐:人類看不到,機器人會填 -->
				<label class="hp" aria-hidden="true">
					<span>Website</span>
					<input type="text" name="website" tabindex="-1" autocomplete="off" />
				</label>
				<button type="submit" class="btn-send">送出訊息 →</button>
				<p class="form-msg" hidden></p>
			</form>

			<p class="alt">
				表單怪怪的?也可以在
				<a href="https://www.instagram.com/huisangie" target="_blank" rel="noopener">Instagram @huisangie</a>
				或
				<a href="https://www.facebook.com/angiehu" target="_blank" rel="noopener">Facebook</a> 私訊我。
			</p>
		</main>
		<Footer />

		<style>
			.contact-main {
				width: 680px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3rem 1em 2rem;
			}
			h1 {
				font-size: 2.3rem;
				font-weight: 700;
			}
			.lede {
				color: rgb(var(--gray));
				margin: 0.5rem 0 2rem;
			}
			form {
				display: grid;
				gap: 1.1rem;
			}
			.grid2 {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1.1rem;
			}
			label {
				display: grid;
				gap: 0.4rem;
			}
			label span {
				font-size: 0.88rem;
				font-weight: 600;
				color: var(--ink);
			}
			input,
			textarea {
				font-family: var(--font-sans);
				font-size: 1rem;
				padding: 0.7rem 1rem;
				border-radius: 12px;
				border: 1px solid var(--line);
				background: rgba(255, 255, 255, 0.72);
				backdrop-filter: blur(8px);
				color: var(--ink);
				width: 100%;
				box-sizing: border-box;
			}
			input:focus,
			textarea:focus {
				outline: none;
				border-color: var(--peri);
				box-shadow: 0 0 0 3px rgba(107, 124, 245, 0.18);
			}
			.hp {
				position: absolute;
				left: -9999px;
				height: 0;
				overflow: hidden;
			}
			.btn-send {
				font-family: var(--font-display);
				font-weight: 500;
				font-size: 1rem;
				padding: 0.95rem 1.8rem;
				border-radius: 14px;
				border: 0;
				background: var(--peri);
				color: #fff;
				cursor: pointer;
				justify-self: start;
				box-shadow: 0 10px 30px rgba(107, 124, 245, 0.35);
				transition:
					transform 0.25s,
					box-shadow 0.25s;
			}
			.btn-send:hover {
				transform: translateY(-3px);
				box-shadow: 0 16px 40px rgba(107, 124, 245, 0.45);
			}
			.btn-send:disabled {
				opacity: 0.6;
				transform: none;
				cursor: wait;
			}
			.form-msg {
				font-weight: 600;
				padding: 1rem 1.2rem;
				border-radius: 12px;
			}
			.form-msg.ok {
				background: rgba(107, 124, 245, 0.12);
				color: var(--peri-deep);
			}
			.form-msg.err {
				background: rgba(220, 100, 80, 0.12);
				color: #b0452e;
			}
			.alt {
				margin-top: 2rem;
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}
			.alt a {
				color: var(--peri-deep);
			}
			@media (max-width: 560px) {
				.grid2 {
					grid-template-columns: 1fr;
				}
			}
		</style>

		<script>
			const form = document.getElementById('contact-form') as HTMLFormElement;
			const msg = form.querySelector('.form-msg') as HTMLElement;
			const btn = form.querySelector('.btn-send') as HTMLButtonElement;

			// 從其他頁帶主題進來(例如顧問頁 /contact?subject=顧問諮詢)
			const preSubject = new URL(location.href).searchParams.get('subject');
			if (preSubject) {
				const sub = form.querySelector('[name="subject"]') as HTMLInputElement | null;
				if (sub) sub.value = preSubject;
			}

			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				const data = Object.fromEntries(new FormData(form).entries());
				if (!data.name || !data.email || !data.message) {
					show('err', '請至少填「稱呼、Email、想說的話」三格 🙏');
					return;
				}
				btn.disabled = true;
				btn.textContent = '送出中…';
				try {
					const r = await fetch('/api/contact', {
						method: 'POST',
						headers: { 'content-type': 'application/json' },
						body: JSON.stringify(data),
					});
					const j = await r.json();
					if (j.ok) {
						form.reset();
						show('ok', '收到了!我會盡快用 Email 回覆你 😊');
						btn.textContent = '已送出 ✓';
					} else {
						throw new Error(j.error || 'failed');
					}
				} catch {
					show(
						'err',
						'送出失敗了 😥 請稍後再試一次,或到 Instagram @huisangie 私訊我',
					);
					btn.disabled = false;
					btn.textContent = '送出訊息 →';
				}
			});

			function show(kind: 'ok' | 'err', text: string) {
				msg.hidden = false;
				msg.className = 'form-msg ' + kind;
				msg.textContent = text;
			}
		</script>
	</body>
</html>
