---
import { marked } from 'marked';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import about from '../data/about.json';

const blocks = about.blocks ?? [];
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title={about.title} description={about.description} />
	</head>
	<body>
		<Header />
		<main class="about-main">
			<h1>{about.title}</h1>

			{
				blocks.map((block) => {
					if (block.type === 'richText') {
						return (
							<section class="ab-block prose-block">
								{block.heading && <h2>{block.heading}</h2>}
								{block.body && <div set:html={marked.parse(block.body)} />}
							</section>
						);
					}
					if (block.type === 'clients') {
						return (
							<section class="ab-block">
								{block.heading && <h2>{block.heading}</h2>}
								{block.intro && <p>{block.intro}</p>}
								<ul class="clients">
									{(block.items ?? []).map((c) => (
										<li>{c}</li>
									))}
								</ul>
							</section>
						);
					}
					if (block.type === 'figure') {
						return (
							<figure class="ab-block">
								<img src={block.image} alt={block.caption || ''} loading="lazy" />
								{block.caption && <figcaption>{block.caption}</figcaption>}
							</figure>
						);
					}
					if (block.type === 'audio') {
						return (
							<section class="ab-block">
								{block.title && <p class="audio-title">{block.title}</p>}
								{block.file ? (
									<audio controls preload="metadata" src={block.file} />
								) : (
									block.note && <div class="audio-placeholder">{block.note}</div>
								)}
							</section>
						);
					}
					if (block.type === 'links') {
						return (
							<section class="ab-block">
								{block.heading && <h2>{block.heading}</h2>}
								<ul class="contact-links">
									{(block.items ?? []).map((l) => (
										<li>
											<a href={l.url} target={l.url.startsWith('mailto:') ? undefined : '_blank'} rel="noopener">
												{l.label}
											</a>
										</li>
									))}
								</ul>
							</section>
						);
					}
					return null;
				})
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.about-main {
		width: 760px;
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 3rem 1em 2rem;
	}
	.about-main h1 {
		font-size: 2.4rem;
		font-weight: 800;
		margin: 0 0 2rem;
	}
	.ab-block {
		margin: 0 0 2.2rem;
	}
	.ab-block h2 {
		font-size: 1.55rem;
		font-weight: 800;
		margin: 0 0 0.8rem;
	}
	.prose-block :global(a) {
		color: var(--accent-dark);
	}
	.clients {
		list-style: none;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}
	.clients li {
		background: rgba(var(--accent-soft), 0.12);
		color: var(--accent-dark);
		border: 1px solid rgba(var(--accent-soft), 0.3);
		border-radius: 999px;
		padding: 0.4rem 1rem;
		font-size: 0.9rem;
		font-weight: 600;
	}
	figure.ab-block {
		margin-inline: 0;
	}
	figure.ab-block img {
		width: 100%;
		height: auto;
		border-radius: 12px;
		border: 1px solid rgb(var(--gray-light));
	}
	figcaption {
		font-size: 0.85rem;
		color: rgb(var(--gray));
		margin-top: 0.5rem;
		text-align: center;
	}
	.audio-title {
		font-weight: 700;
		margin: 0 0 0.6rem;
	}
	.audio-placeholder {
		background: rgba(var(--accent-soft), 0.1);
		border: 1px dashed rgba(var(--accent-soft), 0.5);
		border-radius: 12px;
		padding: 1rem 1.2rem;
		font-size: 0.95rem;
		color: rgb(var(--gray-dark));
	}
	.contact-links {
		list-style: none;
		padding: 0;
		display: grid;
		gap: 0.5rem;
	}
	.contact-links a {
		color: var(--accent-dark);
		font-weight: 600;
	}
</style>
