---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { marked } from 'marked';
import HeroV2 from '../components/HeroV2.astro';
import { websiteSchema } from '../utils/schema';
import home from '../data/home.json';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
// 工具卡從「AI 工具」集合來(後台可各自編輯介紹頁),依 order 排序
const allTools = (await getCollection('tools')).sort(
	(a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
const blocks = home.blocks ?? [];
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead
			title={SITE_TITLE}
			description={SITE_DESCRIPTION}
			schema={websiteSchema(SITE_TITLE, SITE_DESCRIPTION)}
		/>
	</head>
	<body>
		<Header />

		{
			blocks.map((block) => {
				/* ---------- HERO(柔和科技風 v2)---------- */
				if (block.type === 'hero') {
					return <HeroV2 {...block} />;
				}

				/* ---------- TOOLS(分類+搜尋)---------- */
				if (block.type === 'tools') {
					const allCats = [...new Set(allTools.flatMap((t) => t.data.tags ?? []))];
					return (
						<section id="tools" class="block">
							<div class="container">
								<div class="block-head">
									<h2>{block.heading}</h2>
									{block.subtitle && <p class="muted">{block.subtitle}</p>}
								</div>

								<div class="tool-controls">
									<div class="cat-chips" role="tablist">
										<button class="cchip is-active" data-cat="__all">
											全部
										</button>
										{allCats.map((c) => (
											<button class="cchip" data-cat={c}>
												{c}
											</button>
										))}
									</div>
									<input
										id="tool-search"
										type="search"
										placeholder="🔍 搜尋工具…"
										aria-label="搜尋工具"
									/>
								</div>

								<div class="tool-grid">
									{allTools.map((tool, i) => {
										const t = tool.data;
										const isOpen = t.status === 'live';
										const badge =
											t.status === 'internal'
												? '🔒 內部工具 · 對外版本開發中'
												: '🚧 對外版本開發中,敬請期待';
										const searchText = [
											t.name,
											t.desc,
											t.tag,
											...(t.features ?? []),
											...(t.keywords ?? []),
											...(t.tags ?? []),
										]
											.join(' ')
											.toLowerCase();
										return (
											<a
												class="tool-card"
												href={`/tools/${tool.id}/`}
												data-cats={(t.tags ?? []).join(',')}
												data-search={searchText}
											>
												{t.badge && (
													<span class={`tool-badge tool-badge--${t.badge}`}>
														{t.badge === 'update' ? 'UPDATE' : 'NEW'}
													</span>
												)}
												<div class="tool-visual" data-v={i % 4}>
													{t.cover ? (
														<img src={t.cover} alt="" loading="lazy" />
													) : (
														<span class="tv-icon" aria-hidden="true">
															{t.icon}
														</span>
													)}
												</div>
												<div class="tool-body">
													{t.tag && <span class="tool-tag">{t.tag}</span>}
													<h3>{t.name}</h3>
													<p>{t.desc}</p>
													{t.features && t.features.length > 0 && (
														<ul class="tool-features">
															{t.features.map((f) => (
																<li>{f}</li>
															))}
														</ul>
													)}
												</div>
												{isOpen ? (
													<span class="tool-go">了解更多 →</span>
												) : (
													<span class="tool-status">{badge}</span>
												)}
											</a>
										);
									})}
								</div>
								<p class="tool-empty muted" hidden>
									沒有符合的工具 🔍 換個關鍵字試試
								</p>
								{block.note && <p class="placeholder-note">{block.note}</p>}
							</div>
						</section>
					);
				}

				/* ---------- LATEST POSTS ---------- */
				if (block.type === 'latestPosts') {
					const posts = allPosts.slice(0, block.count ?? 3);
					return (
						<section class="block">
							<div class="container">
								<div class="block-head">
									<h2>{block.heading}</h2>
									<a class="see-all" href="/blog">
										看全部 →
									</a>
								</div>
								{posts.length === 0 ? (
									<p class="muted">文章搬家中,敬請期待 ✨</p>
								) : (
									<div class="home-posts">
										{posts.map((post, i) => (
											<a class="hp-card" href={`/blog/${post.id}/`}>
												{post.data.heroImage ? (
													<img class="hp-img" src={post.data.heroImage} alt="" loading="lazy" />
												) : (
													<div class="hp-img hp-img--empty" data-v={i % 4} aria-hidden="true">
														✍️
													</div>
												)}
												<div class="hp-body">
													{(post.data.tags ?? []).slice(0, 1).map((t) => (
														<span class="tool-tag">{t}</span>
													))}
													<h3 class="hp-title">{post.data.title}</h3>
													<FormattedDate date={post.data.pubDate} />
												</div>
											</a>
										))}
									</div>
								)}
							</div>
						</section>
					);
				}

				/* ---------- RICH TEXT ---------- */
				if (block.type === 'richText') {
					return (
						<section class="block">
							<div class="container prose-block">
								{block.heading && <h2>{block.heading}</h2>}
								{block.body && <div set:html={marked.parse(block.body)} />}
							</div>
						</section>
					);
				}

				/* ---------- CTA ---------- */
				if (block.type === 'cta') {
					return (
						<section class="block">
							<div class="container">
								<div class="cta-box">
									<div>
										<h2>{block.heading}</h2>
										{block.text && <p class="muted">{block.text}</p>}
									</div>
									{block.buttonLabel && (
										<a class="btn btn-primary" href={block.buttonHref || '#'}>
											{block.buttonLabel}
										</a>
									)}
								</div>
							</div>
						</section>
					);
				}

				return null;
			})
		}

		<Footer />
	</body>
</html>

<style>
	.container {
		width: 1080px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
	}
	.block {
		padding: 0 0 1rem;
		margin-bottom: 3.5rem;
	}
	/* 捲動進場:區塊浮現 */
	.will-reveal {
		opacity: 0;
		transform: translateY(28px);
		transition:
			opacity 0.8s cubic-bezier(0.2, 0.7, 0.2, 1),
			transform 0.8s cubic-bezier(0.2, 0.7, 0.2, 1);
	}
	.will-reveal.in {
		opacity: 1;
		transform: none;
	}
	@media (prefers-reduced-motion: reduce) {
		.will-reveal {
			opacity: 1;
			transform: none;
			transition: none;
		}
	}

	/* ---------- 按鈕(CTA 區塊沿用)---------- */
	.btn {
		display: inline-block;
		padding: 0.8rem 1.5rem;
		border-radius: 999px;
		font-weight: 700;
		text-decoration: none;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease,
			background 0.15s ease;
	}
	.btn-primary {
		background: var(--accent);
		color: #fff;
		box-shadow: 0 8px 22px rgba(var(--accent-soft), 0.35);
	}
	.btn-primary:hover {
		background: var(--accent-dark);
		transform: translateY(-2px);
	}
	.btn-ghost {
		color: var(--accent-dark);
		border: 1px solid rgb(var(--gray-light));
		background: var(--surface);
	}
	.btn-ghost:hover {
		border-color: var(--accent);
		transform: translateY(-2px);
	}

	/* ---------- shared section head ---------- */
	.block-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
		margin-bottom: 1.6rem;
	}
	.block-head h2 {
		font-size: 1.8rem;
		font-weight: 800;
		margin: 0;
	}
	.muted {
		color: rgb(var(--gray));
		margin: 0;
	}
	.see-all {
		font-weight: 700;
		text-decoration: none;
		white-space: nowrap;
		color: var(--accent-dark);
	}

	/* ---------- TOOL 控制列(分類+搜尋)---------- */
	.tool-controls {
		display: flex;
		gap: 1rem;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		margin-bottom: 1.4rem;
	}
	.cat-chips {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}
	.cchip {
		font-family: var(--font-sans);
		font-size: 0.88rem;
		font-weight: 600;
		padding: 0.45rem 1rem;
		border-radius: 999px;
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.72);
		backdrop-filter: blur(8px);
		color: var(--ink);
		cursor: pointer;
		transition: 0.2s ease;
	}
	.cchip:hover {
		border-color: var(--peri);
		color: var(--peri-deep);
	}
	.cchip.is-active {
		background: var(--peri);
		color: #fff;
		border-color: var(--peri);
		box-shadow: 0 6px 18px rgba(107, 124, 245, 0.3);
	}
	#tool-search {
		font-family: var(--font-sans);
		font-size: 0.92rem;
		padding: 0.55rem 1.1rem;
		border-radius: 999px;
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.72);
		backdrop-filter: blur(8px);
		color: var(--ink);
		min-width: 220px;
	}
	#tool-search:focus {
		outline: none;
		border-color: var(--peri);
		box-shadow: 0 0 0 3px rgba(107, 124, 245, 0.18);
	}
	.tool-empty {
		text-align: center;
		padding: 2rem 0;
	}

	/* ---------- TOOL GRID ---------- */
	.tool-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
		gap: 1.25rem;
	}
	.tool-card {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		padding: 0 0 1.6rem;
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.72);
		backdrop-filter: blur(8px);
		border: 1px solid var(--line);
		text-decoration: none;
		color: inherit;
		overflow: hidden;
		transition:
			transform 0.18s ease,
			box-shadow 0.18s ease,
			border-color 0.18s ease;
	}
	.tool-card .tool-body,
	.tool-card .tool-status,
	.tool-card .tool-go {
		margin-left: 1.6rem;
		margin-right: 1.6rem;
	}
	/* 右上角斜貼的紅色小貼紙:NEW / UPDATE */
	.tool-badge {
		position: absolute;
		top: 12px;
		right: 10px;
		z-index: 3;
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 0.6rem;
		letter-spacing: 0.1em;
		color: #fff;
		background: #e5484d;
		padding: 4px 10px;
		border-radius: 5px;
		transform: rotate(6deg);
		box-shadow: 0 3px 9px rgba(200, 30, 40, 0.38);
		pointer-events: none;
	}
	/* NEW / UPDATE 都用同一個紅,靠文字區分 */
	/* 視覺區:有截圖用截圖,沒有用柔和漸層+大圖示(4 種變化輪流) */
	.tool-visual {
		width: 100%;
		aspect-ratio: 16 / 9;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		overflow: hidden;
	}
	.tool-visual img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
	}
	.tv-icon {
		font-size: 3.4rem;
		line-height: 1;
		filter: drop-shadow(0 8px 18px rgba(38, 42, 63, 0.18));
	}
	.tool-visual[data-v='0'] {
		background:
			radial-gradient(120% 100% at 15% 0%, var(--lav) 0%, transparent 60%),
			radial-gradient(120% 110% at 90% 100%, #8fa0f8 0%, transparent 65%),
			linear-gradient(135deg, #eef0ff, #dfe4ff);
	}
	.tool-visual[data-v='1'] {
		background:
			radial-gradient(120% 100% at 85% 0%, var(--peach) 0%, transparent 60%),
			radial-gradient(120% 110% at 10% 100%, #ffc9ab 0%, transparent 65%),
			linear-gradient(135deg, #fff3ea, #ffe4d3);
	}
	.tool-visual[data-v='2'] {
		background:
			radial-gradient(120% 100% at 20% 0%, var(--mint) 0%, transparent 60%),
			radial-gradient(120% 110% at 85% 100%, #b8d8c8 0%, transparent 65%),
			linear-gradient(135deg, #edf6f1, #dcece3);
	}
	.tool-visual[data-v='3'] {
		background:
			radial-gradient(120% 100% at 80% 0%, var(--lav) 0%, transparent 55%),
			radial-gradient(120% 110% at 15% 100%, var(--peach) 0%, transparent 60%),
			linear-gradient(135deg, #f4efff, #ffeadd);
	}
	.tool-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 16px 34px rgba(var(--gray), 0.16);
		border-color: rgba(var(--accent-soft), 0.55);
	}
	.tool-icon {
		font-size: 2.1rem;
		line-height: 1;
	}
	.tool-tag {
		display: inline-block;
		font-size: 0.7rem;
		letter-spacing: 0.06em;
		font-weight: 700;
		color: var(--accent-dark);
		background: rgba(var(--accent-soft), 0.14);
		padding: 0.25rem 0.6rem;
		border-radius: 999px;
		margin-bottom: 0.6rem;
	}
	.tool-body h3 {
		font-size: 1.2rem;
		font-weight: 800;
		margin: 0 0 0.35rem;
	}
	.tool-body p {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.94rem;
		line-height: 1.55;
	}
	.tool-go {
		font-weight: 700;
		color: var(--accent-dark);
		font-size: 0.94rem;
		margin-top: auto;
	}
	.tool-features {
		list-style: none;
		margin: 0.9rem 0 0;
		padding: 0;
		display: grid;
		gap: 0.35rem;
	}
	.tool-features li {
		position: relative;
		padding-left: 1.1rem;
		font-size: 0.86rem;
		color: rgb(var(--gray));
		line-height: 1.45;
	}
	.tool-features li::before {
		content: '✓';
		position: absolute;
		left: 0;
		color: var(--accent);
		font-weight: 700;
	}
	.tool-status {
		margin-top: auto;
		font-weight: 700;
		font-size: 0.82rem;
		color: #9a6a45;
		background: rgba(198, 138, 92, 0.14);
		border-radius: 999px;
		padding: 0.35rem 0.8rem;
		align-self: flex-start;
	}
	.placeholder-note {
		margin-top: 1.5rem;
		font-size: 0.9rem;
		color: rgb(var(--gray));
		background: rgba(var(--accent-soft), 0.1);
		border: 1px dashed rgba(var(--accent-soft), 0.5);
		padding: 0.8rem 1rem;
		border-radius: 12px;
	}

	/* ---------- POST LIST ---------- */
	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-list li + li {
		border-top: 1px solid rgb(var(--gray-light));
	}
	.post-list a {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem 0.25rem;
		text-decoration: none;
		color: inherit;
	}
	.post-list a:hover .post-title {
		color: var(--accent-dark);
	}
	.post-title {
		font-weight: 700;
		font-size: 1.1rem;
	}
	.post-list :global(time) {
		color: rgb(var(--gray));
		font-size: 0.85rem;
		white-space: nowrap;
	}

	/* ---------- HOME POST CARDS (with banner) ---------- */
	.home-posts {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1.25rem;
	}
	.hp-card {
		border: 1px solid rgb(var(--gray-light));
		border-radius: 16px;
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		background: var(--surface);
		transition:
			transform 0.18s ease,
			box-shadow 0.18s ease,
			border-color 0.18s ease;
	}
	.hp-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 16px 34px rgba(var(--gray), 0.16);
		border-color: rgba(var(--accent-soft), 0.55);
	}
	.hp-img {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		display: block;
	}
	.hp-img--empty {
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2.4rem;
	}
	.hp-img--empty[data-v='0'] {
		background:
			radial-gradient(120% 100% at 15% 0%, var(--lav) 0%, transparent 60%),
			linear-gradient(135deg, #eef0ff, #dfe4ff);
	}
	.hp-img--empty[data-v='1'] {
		background:
			radial-gradient(120% 100% at 85% 0%, var(--peach) 0%, transparent 60%),
			linear-gradient(135deg, #fff3ea, #ffe4d3);
	}
	.hp-img--empty[data-v='2'] {
		background:
			radial-gradient(120% 100% at 20% 0%, var(--mint) 0%, transparent 60%),
			linear-gradient(135deg, #edf6f1, #dcece3);
	}
	.hp-img--empty[data-v='3'] {
		background:
			radial-gradient(120% 100% at 80% 0%, var(--lav) 0%, transparent 55%),
			linear-gradient(135deg, #f4efff, #ffeadd);
	}
	.hp-body {
		padding: 1.1rem 1.2rem 1.3rem;
	}
	.hp-title {
		font-size: 1.1rem;
		font-weight: 800;
		line-height: 1.35;
		margin: 0.5rem 0;
	}
	.hp-body :global(time) {
		color: rgb(var(--gray));
		font-size: 0.82rem;
	}

	/* ---------- RICH TEXT + CTA ---------- */
	.prose-block :global(h2) {
		font-size: 1.8rem;
		font-weight: 800;
	}
	.prose-block :global(a) {
		color: var(--accent-dark);
	}
	.cta-box {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		flex-wrap: wrap;
		background: rgba(var(--accent-soft), 0.1);
		border: 1px solid rgba(var(--accent-soft), 0.3);
		border-radius: 20px;
		padding: 2rem;
	}
	.cta-box h2 {
		font-size: 1.6rem;
		font-weight: 800;
		margin: 0 0 0.4rem;
	}

	@media (max-width: 720px) {
		.tool-controls {
			flex-direction: column;
			align-items: stretch;
		}
		#tool-search {
			min-width: 0;
		}
	}
</style>

<script>
	// 工具區:分類篩選 + 關鍵字搜尋(兩者可疊加)
	const chips = document.querySelectorAll<HTMLButtonElement>('.cchip');
	const cards = document.querySelectorAll<HTMLElement>('.tool-card');
	const searchBox = document.getElementById('tool-search') as HTMLInputElement | null;
	const emptyMsg = document.querySelector<HTMLElement>('.tool-empty');

	let activeCat = '__all';

	function applyFilters() {
		const q = (searchBox?.value || '').trim().toLowerCase();
		let shown = 0;
		cards.forEach((card) => {
			const cats = (card.dataset.cats || '').split(',').filter(Boolean);
			const text = card.dataset.search || '';
			const catOk = activeCat === '__all' || cats.includes(activeCat);
			const qOk = !q || text.includes(q);
			const show = catOk && qOk;
			card.style.display = show ? '' : 'none';
			if (show) shown++;
		});
		if (emptyMsg) emptyMsg.hidden = shown !== 0;
	}

	chips.forEach((chip) => {
		chip.addEventListener('click', () => {
			activeCat = chip.dataset.cat || '__all';
			chips.forEach((c) => c.classList.toggle('is-active', c === chip));
			applyFilters();
		});
	});
	searchBox?.addEventListener('input', applyFilters);

	// 捲動進場浮現(尊重減少動態偏好)
	if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
		const io = new IntersectionObserver(
			(entries) => {
				entries.forEach((e) => {
					if (e.isIntersecting) {
						e.target.classList.add('in');
						io.unobserve(e.target);
					}
				});
			},
			{ threshold: 0.12 },
		);
		document.querySelectorAll('.block .container').forEach((el) => {
			el.classList.add('will-reveal');
			io.observe(el);
		});
	}
</script>
