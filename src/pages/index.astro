---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { marked } from 'marked';
import home from '../data/home.json';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
// 工具卡從「AI 工具」集合來(後台可各自編輯介紹頁),依 order 排序
const allTools = (await getCollection('tools')).sort(
	(a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
const blocks = home.blocks ?? [];
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		{
			blocks.map((block) => {
				/* ---------- HERO ---------- */
				if (block.type === 'hero') {
					return (
						<section class="hero">
							<div class="hero-blob" aria-hidden="true" />
							<div class="container hero-inner">
								{block.eyebrow && <p class="eyebrow">{block.eyebrow}</p>}
								<h1>
									{block.heading}
									{block.highlight && <span class="hl">{block.highlight}</span>}
									{block.headingAfter && (
										<>
											<br />
											{block.headingAfter}
										</>
									)}
								</h1>
								{block.lede && <p class="lede">{block.lede}</p>}
								<div class="cta-row">
									{block.primaryLabel && (
										<a class="btn btn-primary" href={block.primaryHref || '#'}>
											{block.primaryLabel}
										</a>
									)}
									{block.ghostLabel && (
										<a class="btn btn-ghost" href={block.ghostHref || '#'}>
											{block.ghostLabel}
										</a>
									)}
								</div>
							</div>
						</section>
					);
				}

				/* ---------- TOOLS ---------- */
				if (block.type === 'tools') {
					return (
						<section id="tools" class="block">
							<div class="container">
								<div class="block-head">
									<h2>{block.heading}</h2>
									{block.subtitle && <p class="muted">{block.subtitle}</p>}
								</div>
								<div class="tool-grid">
									{allTools.map((tool) => {
										const t = tool.data;
										const isInternal = t.status === 'internal';
										return (
											<a class="tool-card" href={`/tools/${tool.id}/`}>
												<div class="tool-icon">{t.icon}</div>
												<div class="tool-body">
													{t.tag && <span class="tool-tag">{t.tag}</span>}
													<h3>{t.name}</h3>
													<p>{t.desc}</p>
													{t.features && t.features.length > 0 && (
														<ul class="tool-features">
															{t.features.map((f) => (
																<li>{f}</li>
															))}
														</ul>
													)}
												</div>
												{isInternal ? (
													<span class="tool-status">🔒 內部使用中 · 對外版本開發中</span>
												) : (
													<span class="tool-go">了解更多 →</span>
												)}
											</a>
										);
									})}
								</div>
								{block.note && <p class="placeholder-note">{block.note}</p>}
							</div>
						</section>
					);
				}

				/* ---------- LATEST POSTS ---------- */
				if (block.type === 'latestPosts') {
					const posts = allPosts.slice(0, block.count ?? 3);
					return (
						<section class="block">
							<div class="container">
								<div class="block-head">
									<h2>{block.heading}</h2>
									<a class="see-all" href="/blog">
										看全部 →
									</a>
								</div>
								{posts.length === 0 ? (
									<p class="muted">文章搬家中,敬請期待 ✨</p>
								) : (
									<div class="home-posts">
										{posts.map((post) => (
											<a class="hp-card" href={`/blog/${post.id}/`}>
												{post.data.heroImage ? (
													<img class="hp-img" src={post.data.heroImage} alt="" loading="lazy" />
												) : (
													<div class="hp-img hp-img--empty" aria-hidden="true">
														✍️
													</div>
												)}
												<div class="hp-body">
													{(post.data.tags ?? []).slice(0, 1).map((t) => (
														<span class="tool-tag">{t}</span>
													))}
													<h3 class="hp-title">{post.data.title}</h3>
													<FormattedDate date={post.data.pubDate} />
												</div>
											</a>
										))}
									</div>
								)}
							</div>
						</section>
					);
				}

				/* ---------- RICH TEXT ---------- */
				if (block.type === 'richText') {
					return (
						<section class="block">
							<div class="container prose-block">
								{block.heading && <h2>{block.heading}</h2>}
								{block.body && <div set:html={marked.parse(block.body)} />}
							</div>
						</section>
					);
				}

				/* ---------- CTA ---------- */
				if (block.type === 'cta') {
					return (
						<section class="block">
							<div class="container">
								<div class="cta-box">
									<div>
										<h2>{block.heading}</h2>
										{block.text && <p class="muted">{block.text}</p>}
									</div>
									{block.buttonLabel && (
										<a class="btn btn-primary" href={block.buttonHref || '#'}>
											{block.buttonLabel}
										</a>
									)}
								</div>
							</div>
						</section>
					);
				}

				return null;
			})
		}

		<Footer />
	</body>
</html>

<style>
	.container {
		width: 1080px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
	}
	.block {
		padding: 0 0 1rem;
		margin-bottom: 3.5rem;
	}

	/* ---------- HERO (clean + soft) ---------- */
	.hero {
		position: relative;
		overflow: hidden;
		padding: 6rem 0 4.5rem;
		isolation: isolate;
	}
	.hero-blob {
		position: absolute;
		z-index: -1;
		top: -18%;
		right: -8%;
		width: 46vw;
		max-width: 620px;
		aspect-ratio: 1;
		background: radial-gradient(
			circle at 50% 50%,
			rgba(var(--accent-soft), 0.22),
			rgba(var(--accent-soft), 0) 68%
		);
		filter: blur(6px);
		animation: drift 16s ease-in-out infinite alternate;
	}
	@keyframes drift {
		from {
			transform: translate(0, 0) scale(1);
		}
		to {
			transform: translate(-28px, 22px) scale(1.08);
		}
	}
	.hero-inner {
		max-width: 820px;
		margin-inline: auto;
	}
	.eyebrow {
		letter-spacing: 0.22em;
		font-size: 0.72rem;
		font-weight: 700;
		color: var(--accent-dark);
		margin: 0 0 1.1rem;
	}
	.hero h1 {
		font-size: clamp(2.3rem, 5.5vw, 3.6rem);
		line-height: 1.18;
		font-weight: 800;
		color: rgb(var(--black));
		margin: 0 0 1.2rem;
		letter-spacing: -0.01em;
	}
	.hl {
		background: linear-gradient(transparent 62%, rgba(var(--accent-soft), 0.35) 62%);
		padding: 0 0.1em;
	}
	.lede {
		font-size: 1.13rem;
		color: rgb(var(--gray));
		max-width: 600px;
		margin: 0 0 2rem;
	}
	.cta-row {
		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
	}
	.btn {
		display: inline-block;
		padding: 0.8rem 1.5rem;
		border-radius: 999px;
		font-weight: 700;
		text-decoration: none;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease,
			background 0.15s ease;
	}
	.btn-primary {
		background: var(--accent);
		color: #fff;
		box-shadow: 0 8px 22px rgba(var(--accent-soft), 0.35);
	}
	.btn-primary:hover {
		background: var(--accent-dark);
		transform: translateY(-2px);
	}
	.btn-ghost {
		color: var(--accent-dark);
		border: 1px solid rgb(var(--gray-light));
		background: var(--surface);
	}
	.btn-ghost:hover {
		border-color: var(--accent);
		transform: translateY(-2px);
	}

	/* ---------- shared section head ---------- */
	.block-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
		margin-bottom: 1.6rem;
	}
	.block-head h2 {
		font-size: 1.8rem;
		font-weight: 800;
		margin: 0;
	}
	.muted {
		color: rgb(var(--gray));
		margin: 0;
	}
	.see-all {
		font-weight: 700;
		text-decoration: none;
		white-space: nowrap;
		color: var(--accent-dark);
	}

	/* ---------- TOOL GRID ---------- */
	.tool-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
		gap: 1.25rem;
	}
	.tool-card {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		padding: 1.6rem;
		border-radius: 18px;
		background: var(--surface);
		border: 1px solid rgb(var(--gray-light));
		text-decoration: none;
		color: inherit;
		transition:
			transform 0.18s ease,
			box-shadow 0.18s ease,
			border-color 0.18s ease;
	}
	.tool-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 16px 34px rgba(var(--gray), 0.16);
		border-color: rgba(var(--accent-soft), 0.55);
	}
	.tool-icon {
		font-size: 2.1rem;
		line-height: 1;
	}
	.tool-tag {
		display: inline-block;
		font-size: 0.7rem;
		letter-spacing: 0.06em;
		font-weight: 700;
		color: var(--accent-dark);
		background: rgba(var(--accent-soft), 0.14);
		padding: 0.25rem 0.6rem;
		border-radius: 999px;
		margin-bottom: 0.6rem;
	}
	.tool-body h3 {
		font-size: 1.2rem;
		font-weight: 800;
		margin: 0 0 0.35rem;
	}
	.tool-body p {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.94rem;
		line-height: 1.55;
	}
	.tool-go {
		font-weight: 700;
		color: var(--accent-dark);
		font-size: 0.94rem;
		margin-top: auto;
	}
	.tool-features {
		list-style: none;
		margin: 0.9rem 0 0;
		padding: 0;
		display: grid;
		gap: 0.35rem;
	}
	.tool-features li {
		position: relative;
		padding-left: 1.1rem;
		font-size: 0.86rem;
		color: rgb(var(--gray));
		line-height: 1.45;
	}
	.tool-features li::before {
		content: '✓';
		position: absolute;
		left: 0;
		color: var(--accent);
		font-weight: 700;
	}
	.tool-status {
		margin-top: auto;
		font-weight: 700;
		font-size: 0.82rem;
		color: #9a6a45;
		background: rgba(198, 138, 92, 0.14);
		border-radius: 999px;
		padding: 0.35rem 0.8rem;
		align-self: flex-start;
	}
	.placeholder-note {
		margin-top: 1.5rem;
		font-size: 0.9rem;
		color: rgb(var(--gray));
		background: rgba(var(--accent-soft), 0.1);
		border: 1px dashed rgba(var(--accent-soft), 0.5);
		padding: 0.8rem 1rem;
		border-radius: 12px;
	}

	/* ---------- POST LIST ---------- */
	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-list li + li {
		border-top: 1px solid rgb(var(--gray-light));
	}
	.post-list a {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem 0.25rem;
		text-decoration: none;
		color: inherit;
	}
	.post-list a:hover .post-title {
		color: var(--accent-dark);
	}
	.post-title {
		font-weight: 700;
		font-size: 1.1rem;
	}
	.post-list :global(time) {
		color: rgb(var(--gray));
		font-size: 0.85rem;
		white-space: nowrap;
	}

	/* ---------- HOME POST CARDS (with banner) ---------- */
	.home-posts {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1.25rem;
	}
	.hp-card {
		border: 1px solid rgb(var(--gray-light));
		border-radius: 16px;
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		background: var(--surface);
		transition:
			transform 0.18s ease,
			box-shadow 0.18s ease,
			border-color 0.18s ease;
	}
	.hp-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 16px 34px rgba(var(--gray), 0.16);
		border-color: rgba(var(--accent-soft), 0.55);
	}
	.hp-img {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		display: block;
	}
	.hp-img--empty {
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2rem;
		background: rgba(var(--accent-soft), 0.1);
	}
	.hp-body {
		padding: 1.1rem 1.2rem 1.3rem;
	}
	.hp-title {
		font-size: 1.1rem;
		font-weight: 800;
		line-height: 1.35;
		margin: 0.5rem 0;
	}
	.hp-body :global(time) {
		color: rgb(var(--gray));
		font-size: 0.82rem;
	}

	/* ---------- RICH TEXT + CTA ---------- */
	.prose-block :global(h2) {
		font-size: 1.8rem;
		font-weight: 800;
	}
	.prose-block :global(a) {
		color: var(--accent-dark);
	}
	.cta-box {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		flex-wrap: wrap;
		background: rgba(var(--accent-soft), 0.1);
		border: 1px solid rgba(var(--accent-soft), 0.3);
		border-radius: 20px;
		padding: 2rem;
	}
	.cta-box h2 {
		font-size: 1.6rem;
		font-weight: 800;
		margin: 0 0 0.4rem;
	}

	@media (max-width: 720px) {
		.hero {
			padding: 4rem 0 3rem;
		}
	}
</style>
