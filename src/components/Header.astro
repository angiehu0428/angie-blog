---
import { SITE_TITLE, SITE_NAV, SITE_CTA } from '../consts';
import HeaderLink from './HeaderLink.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			{
				SITE_NAV.map((item) =>
					item.external ? (
						<a class="ext-link" href={item.href} target="_blank" rel="noopener">
							{item.label} ↗
						</a>
					) : (
						<HeaderLink href={item.href}>{item.label}</HeaderLink>
					),
				)
			}
		</div>
		<div class="right-links">
			<LanguageSwitcher />
			{
				SITE_CTA.label && SITE_CTA.href && (
					<a class="pill" href={SITE_CTA.href} target="_blank" rel="noopener">
						{SITE_CTA.label}
					</a>
				)
			}
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--surface);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.ext-link {
		font-weight: 600;
		color: var(--accent-dark);
	}
	.right-links {
		display: flex;
		align-items: center;
		gap: 0.8rem;
	}
	.pill {
		font-size: 0.88rem;
		text-decoration: none;
		color: var(--peri-deep);
		border: 1.5px solid rgba(107, 124, 245, 0.45);
		padding: 8px 18px !important;
		border-radius: 99px;
		transition: 0.3s;
		background: rgba(255, 255, 255, 0.5);
		backdrop-filter: blur(6px);
		border-bottom: 1.5px solid rgba(107, 124, 245, 0.45) !important;
	}
	.pill:hover {
		background: var(--peri);
		color: #fff !important;
		border-color: var(--peri) !important;
	}
	@media (max-width: 720px) {
		.ext-link {
			display: none;
		}
	}
</style>
